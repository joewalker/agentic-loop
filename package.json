{
  "name": "loop-the-loop",
  "version": "0.0.1",
  "description": "Framework for running generated prompts through coding agents",
  "author": "Joe Walker <jwalker@mozilla.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joewalker/loop-the-loop.git"
  },
  "bugs": {
    "url": "https://github.com/joewalker/loop-the-loop/issues"
  },
  "homepage": "https://github.com/joewalker/loop-the-loop#readme",
  "keywords": [
    "agents",
    "automation",
    "cli",
    "codex",
    "prompts"
  ],
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "schema"
  ],
  "bin": {
    "loop-the-loop": "./dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist cache/tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist cache/tsconfig.build.tsbuildinfo",
    "compile": "deno compile --sloppy-imports --allow-read --allow-write --allow-run --allow-env --allow-net --output=dist/loop-the-loop src/cli.ts",
    "format": "oxfmt",
    "lint": "oxlint src",
    "prepack": "pnpm build",
    "test": "NODE_ENV=test vitest run",
    "tsc": "node ./node_modules/typescript/bin/tsc --build tsconfig.json"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "engines": {
    "node": ">= 22.0"
  },
  "packageManager": "pnpm@11.1.2",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.142",
    "glob": "13.0.6"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "@vitest/coverage-v8": "4.1.6",
    "ajv": "8.20.0",
    "nyc": "18.0.0",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "typescript": "6.0.3",
    "v8-to-istanbul": "9.3.0",
    "vitest": "4.1.6"
  }
}
